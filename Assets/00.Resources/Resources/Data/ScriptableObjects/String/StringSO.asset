    cn: 
  - string_id: 44038
    category: active_skill
    context: "\uC2A4\uD0AC \uD6A8\uACFC \uC11C\uC220"
    kr: "\uC801\uC911\uD55C \uC801\uC758 \uC774\uB3D9 \uC18D\uB3C4\uAC00 \uAC10\uC18C\uD569\uB2C8\uB2E4."
