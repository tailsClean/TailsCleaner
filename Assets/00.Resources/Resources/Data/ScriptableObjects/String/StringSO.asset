    category: active_skill
    context: "\uC2A4\uD0AC \uD6A8\uACFC \uC11C\uC220"
    kr: "\uACF5\uACA9 \uBC94\uC704\uC5D0 \uC788\uB294 \uC801\uC758 \uD22C\uC0AC\uCCB4\uB97C
      \uC81C\uAC70\uD569\uB2C8\uB2E4."
