    context: "\uC2A4\uD0AC \uD6A8\uACFC \uC11C\uC220"
    kr: "\uD30C\uB3C4\uAC00 \uD55C \uBC88 \uC655\uBCF5\uD569\uB2C8\uB2E4. \uC801\uC774
