    cn: 
  - string_id: 44041
    category: active_skill
    context: "\uC2A4\uD0AC \uD6A8\uACFC \uC11C\uC220"
    kr: "\uC77C\uC815 \uC2DC\uAC04\uB9C8\uB2E4 \uD654\uBA74 \uBC16\uC5D0\uC11C \uD50C\uB808\uC774\uC5B4
      \uACF5\uACA9 \uBC29\uD5A5\uC73C\uB85C \uAC70\uD488 \uD30C\uB3C4\uAC00 \uB098\uD0C0\uB098
