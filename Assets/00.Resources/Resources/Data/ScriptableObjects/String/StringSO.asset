  - string_id: 44035
    category: active_skill
    context: "\uC2A4\uD0AC \uD6A8\uACFC \uC11C\uC220"
    kr: "\uD0C0\uC62C \uD718\uB450\uB974\uAE30\uC758 \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C
      \uAC78\uB808 \uD718\uB450\uB974\uAE30\uC758 \uC5C5\uADF8\uB808\uC774\uB4DC\uB85C\uB3C4
