    cn: 
  - string_id: 44040
    category: active_skill
    context: "\uC2A4\uD0AC \uD6A8\uACFC \uC11C\uC220"
    kr: "\uAC78\uB808 \uD718\uB450\uB974\uAE30\uC758 \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C
