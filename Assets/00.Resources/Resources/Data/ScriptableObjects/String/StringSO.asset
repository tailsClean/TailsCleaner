    cn: 
  - string_id: 44024
    category: active_skill
    context: "\uC2A4\uD0AC \uD6A8\uACFC \uC11C\uC220"
    kr: "\uAD00\uD1B5 +1, \uD22C\uC0AC\uCCB4\uC758 \uC18D\uB3C4\uAC00 \uAD00\uD1B5\uD560
